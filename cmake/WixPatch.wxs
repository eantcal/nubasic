<?xml version="1.0" encoding="UTF-8"?>
<!--
  WixPatch.wxs  –  nuBASIC MSI post-processing fragment
  ======================================================
  This file is consumed by CPack's WIX generator via
  CPACK_WIX_PATCH_FILE.  It is merged with the auto-generated
  product description AFTER CPack has built the file/directory
  tree.

  Key CPack WIX conventions used here:
    INSTALL_ROOT   – Directory ID for the package installation root
                     (e.g. C:\Program Files\nuBASIC\).
                     CPack sets WIXUI_INSTALLDIR="INSTALL_ROOT".
    CM_PACKAGE     – The root Feature ID that CPack creates for all
                     installed components.  New components must be
                     referenced here to appear in the installer.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <!-- ============================================================
       Start Menu folder with shortcuts for IDE, CLI and Uninstall
       ============================================================ -->
  <Fragment>
    <DirectoryRef Id="ProgramMenuFolder">
      <Directory Id="NuBASIC_MenuDir" Name="nuBASIC">

        <Component Id="CM_COMP_StartMenuShortcuts"
                   Guid="{B3D7E2A1-4F8C-4A9B-8E2F-1A2B3C4D5E6F}">

          <!-- nuBASIC IDE shortcut -->
          <Shortcut Id="NuBASIC_IDE_Link"
                    Name="nuBASIC IDE"
                    Description="nuBASIC Integrated Development Environment"
                    Target="[INSTALL_ROOT]bin\NuBasicIDE.exe"
                    WorkingDirectory="INSTALL_ROOT" />

          <!-- nuBASIC CLI shortcut -->
          <Shortcut Id="NuBASIC_CLI_Link"
                    Name="nuBASIC Console"
                    Description="nuBASIC Command-Line Interpreter"
                    Target="[INSTALL_ROOT]bin\nubasic.exe"
                    WorkingDirectory="INSTALL_ROOT" />

          <!-- Uninstall shortcut -->
          <Shortcut Id="NuBASIC_Uninstall_Link"
                    Name="Uninstall nuBASIC"
                    Target="[SystemFolder]msiexec.exe"
                    Arguments="/x [ProductCode]" />

          <!-- Registry key path (required for registry-only components) -->
          <RegistryValue Root="HKCU"
                         Key="Software\nuBASIC"
                         Name="StartMenuInstalled"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />

          <!-- Remove the nuBASIC sub-folder from the Start Menu on uninstall -->
          <RemoveFolder Id="NuBASIC_MenuDir_Remove"
                        Directory="NuBASIC_MenuDir"
                        On="uninstall" />

        </Component>
      </Directory>
    </DirectoryRef>
  </Fragment>

  <!-- ============================================================
       Runtime registry values
         HKCU\Software\nuBASIC\InstallDir   – install root path
         HKCU\Software\nuBASIC\ExamplesDir  – examples sub-folder
       These are read at startup by the IDE and the CLI to locate
       built-in example files.
       ============================================================ -->
  <Fragment>
    <DirectoryRef Id="INSTALL_ROOT">
      <Component Id="CM_COMP_RegistryKeys"
                 Guid="{C2E3F4A5-6789-4BCD-EF01-234567890ABC}">

        <RegistryValue Root="HKCU"
                       Key="Software\nuBASIC"
                       Name="InstallDir"
                       Type="string"
                       Value="[INSTALL_ROOT]"
                       KeyPath="yes" />

        <RegistryValue Root="HKCU"
                       Key="Software\nuBASIC"
                       Name="ExamplesDir"
                       Type="string"
                       Value="[INSTALL_ROOT]examples\" />

      </Component>
    </DirectoryRef>
  </Fragment>

  <!-- ============================================================
       .bas file-type association
       Opens nuBASICFile documents with NuBasicIDE.exe.
       Written to HKCU\Software\Classes so no elevation is needed
       and the association applies to the installing user.
       ============================================================ -->
  <Fragment>
    <DirectoryRef Id="INSTALL_ROOT">
      <Component Id="CM_COMP_BASFileAssoc"
                 Guid="{D3F4A5B6-7890-4CDE-F012-34567890BCDE}">

        <!-- .bas extension → ProgID -->
        <RegistryValue Root="HKCU"
                       Key="Software\Classes\.bas"
                       Type="string"
                       Value="nuBASICFile"
                       KeyPath="yes" />

        <!-- ProgID description -->
        <RegistryValue Root="HKCU"
                       Key="Software\Classes\nuBASICFile"
                       Type="string"
                       Value="nuBASIC Source File" />

        <!-- Icon: first icon in NuBasicIDE.exe -->
        <RegistryValue Root="HKCU"
                       Key="Software\Classes\nuBASICFile\DefaultIcon"
                       Type="string"
                       Value="[INSTALL_ROOT]bin\NuBasicIDE.exe,0" />

        <!-- Open verb: launch IDE with the file path as argument -->
        <RegistryValue Root="HKCU"
                       Key="Software\Classes\nuBASICFile\shell\open\command"
                       Type="string"
                       Value="&quot;[INSTALL_ROOT]bin\NuBasicIDE.exe&quot; &quot;%1&quot;" />

        <!-- Notify the shell about the new association -->
        <RegistryValue Root="HKCU"
                       Key="Software\Microsoft\Windows\CurrentVersion\Explorer\FileExts\.bas\UserChoice"
                       Name="ProgId"
                       Type="string"
                       Value="nuBASICFile" />

      </Component>
    </DirectoryRef>
  </Fragment>

  <!-- ============================================================
       Wire all new components into the root CPack feature so they
       are included in the default installation.
       ============================================================ -->
  <Fragment>
    <FeatureRef Id="CM_PACKAGE">
      <ComponentRef Id="CM_COMP_StartMenuShortcuts" />
      <ComponentRef Id="CM_COMP_RegistryKeys" />
      <ComponentRef Id="CM_COMP_BASFileAssoc" />
    </FeatureRef>
  </Fragment>

</Wix>
