<?xml version="1.0" encoding="UTF-8"?>
<!--
  WixPatch.wxs  -  nuBASIC WiX extra source
  ==========================================
  Consumed by CPack via CPACK_WIX_EXTRA_SOURCES.
  Standard WiX v3 fragment file compiled alongside the CPack-generated WXS.

  ProgramMenuFolder and DesktopFolder are declared under TARGETDIR so WiX
  can resolve them as standard Windows Installer virtual folders.

  All components are wired into ProductFeature (the ID CPack generates for
  the root feature) via FeatureRef so WiX includes them and does not
  garbage-collect the fragments.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <!-- ============================================================
       Start Menu folder: Programs\nuBASIC
       ============================================================ -->
  <Fragment>
    <DirectoryRef Id="TARGETDIR">
      <Directory Id="ProgramMenuFolder">
        <Directory Id="NuBASIC_MenuDir" Name="nuBASIC">
          <Component Id="CM_COMP_StartMenuShortcuts"
                     Guid="{B3D7E2A1-4F8C-4A9B-8E2F-1A2B3C4D5E6F}">
            <CreateFolder/>
            <Shortcut Id="NuBASIC_IDE_Link"
                      Name="nuBASIC IDE"
                      Description="nuBASIC Integrated Development Environment"
                      Target="[INSTALL_ROOT]bin\NuBasicIDE.exe"
                      WorkingDirectory="INSTALL_ROOT"/>
            <Shortcut Id="NuBASIC_CLI_Link"
                      Name="nuBASIC Console"
                      Description="nuBASIC Command-Line Interpreter"
                      Target="[INSTALL_ROOT]bin\nubasic.exe"
                      WorkingDirectory="INSTALL_ROOT"/>
            <Shortcut Id="NuBASIC_Uninstall_Link"
                      Name="Uninstall nuBASIC"
                      Target="[SystemFolder]msiexec.exe"
                      Arguments="/x [ProductCode]"/>
            <RemoveFolder Id="NuBASIC_MenuDir_Remove"
                          Directory="NuBASIC_MenuDir"
                          On="uninstall"/>
          </Component>
        </Directory>
      </Directory>

      <!-- Desktop shortcut.
           DesktopFolder is system-managed: no CreateFolder/RemoveFolder.
           Registry value used as KeyPath. -->
      <Directory Id="DesktopFolder">
        <Component Id="CM_COMP_DesktopShortcut"
                   Guid="{E4A5B6C7-8901-4DEF-0123-456789ABCDEF}">
          <Shortcut Id="NuBASIC_Desktop_Link"
                    Name="nuBASIC IDE"
                    Description="nuBASIC Integrated Development Environment"
                    Target="[INSTALL_ROOT]bin\NuBasicIDE.exe"
                    WorkingDirectory="INSTALL_ROOT"/>
          <RegistryValue Root="HKCU"
                         Key="Software\nuBASIC"
                         Name="DesktopShortcut"
                         Type="integer"
                         Value="1"
                         KeyPath="yes"/>
        </Component>
      </Directory>
    </DirectoryRef>
  </Fragment>

  <!-- ============================================================
       Registry keys and .bas file association
       ============================================================ -->
  <Fragment>
    <DirectoryRef Id="INSTALL_ROOT">
      <Component Id="CM_COMP_RegistryKeys"
                 Guid="{C2E3F4A5-6789-4BCD-EF01-234567890ABC}">
        <RegistryValue Root="HKLM"
                       Key="Software\nuBASIC"
                       Name="InstallDir"
                       Type="string"
                       Value="[INSTALL_ROOT]"
                       KeyPath="yes"/>
        <RegistryValue Root="HKLM"
                       Key="Software\nuBASIC"
                       Name="ExamplesDir"
                       Type="string"
                       Value="[INSTALL_ROOT]examples\"/>
      </Component>

      <Component Id="CM_COMP_BASFileAssoc"
                 Guid="{D3F4A5B6-7890-4CDE-F012-34567890BCDE}">
        <RegistryValue Root="HKCU"
                       Key="Software\Classes\.bas"
                       Type="string"
                       Value="nuBASICFile"
                       KeyPath="yes"/>
        <RegistryValue Root="HKCU"
                       Key="Software\Classes\nuBASICFile"
                       Type="string"
                       Value="nuBASIC Source File"/>
        <RegistryValue Root="HKCU"
                       Key="Software\Classes\nuBASICFile\DefaultIcon"
                       Type="string"
                       Value="[INSTALL_ROOT]bin\NuBasicIDE.exe,0"/>
        <RegistryValue Root="HKCU"
                       Key="Software\Classes\nuBASICFile\shell\open\command"
                       Type="string"
                       Value="&quot;[INSTALL_ROOT]bin\NuBasicIDE.exe&quot; &quot;%1&quot;"/>
      </Component>
    </DirectoryRef>
  </Fragment>

  <!-- ============================================================
       Wire all components into ProductFeature — prevents WiX v3
       garbage-collection and ensures everything is installed.
       ============================================================ -->
  <Fragment>
    <FeatureRef Id="ProductFeature">
      <ComponentRef Id="CM_COMP_StartMenuShortcuts"/>
      <ComponentRef Id="CM_COMP_DesktopShortcut"/>
      <ComponentRef Id="CM_COMP_RegistryKeys"/>
      <ComponentRef Id="CM_COMP_BASFileAssoc"/>
    </FeatureRef>
  </Fragment>

</Wix>
